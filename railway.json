{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false
  },
  "services": {
    "backend": {
      "name": "Backend Laravel",
      "builder": "nixpacks",
      "rootDirectory": "/backend",
      "environment": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "pgsql",
        "PORT": "8080",
        "NIXPACKS_NODE_VERSION": "20"
      }
    },
    "frontend": {
      "name": "Frontend Next.js",
      "builder": "nixpacks",
      "rootDirectory": "/frontend",
      "environment": {
        "NODE_ENV": "production",
        "PORT": "3000",
        "NIXPACKS_NODE_VERSION": "20"
      }
    }
  }
}
